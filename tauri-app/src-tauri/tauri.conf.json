{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Data Backup",
  "version": "0.1.0",
  "identifier": "com.backup.tauri-frontend",
  "build": {
    "beforeDevCommand": "npm run build:sidecar && npm run dev 2>/dev/null & sleep 1",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Data Backup",
        "width": 1100,
        "height": 760,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb","rpm"],
    "externalBin": [
      "bin/backup_server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
