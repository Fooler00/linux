{
  "name": "tauri-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:web": "vue-tsc --noEmit && vite build",
    "build:sidecar": "bash ../scripts/build-backup-sidecar.sh",
    "build": "npm run build:sidecar && npm run build:web",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:e2e:tauri": "wdio ../Test/frontend/wdio.conf.ts",
    "test:e2e:tauri:smoke": "wdio ../Test/frontend/wdio.conf.ts --spec ../Test/frontend/specs/smoke.e2e.ts",
    "test:e2e:tauri:ui-smoke": "wdio ../Test/frontend/wdio.conf.ts --spec ../Test/frontend/specs/app_flows.e2e.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/mocha": "10.0.10",
    "@types/node": "22.20.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@wdio/cli": "9.29.1",
    "@wdio/globals": "9.29.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/mocha-framework": "9.29.1",
    "@wdio/spec-reporter": "9.29.1",
    "@wdio/tauri-service": "1.2.0",
    "@wdio/xvfb": "9.29.1",
    "tsx": "4.23.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10",
    "wait-on": "^9.0.10",
    "webdriverio": "9.29.1"
  },
  "overrides": {
    "@wdio/tauri-service": {
      "@wdio/native-utils": "2.5.0"
    }
  }
}
